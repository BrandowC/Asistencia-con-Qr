# =================================================================
# .env.example — Variables sin secretos reales.
# Copiar a .env y reemplazar los placeholders <...> por valores
# locales no sensibles. NUNCA subir el .env al repositorio.
# =================================================================

# --- MongoDB ---
APP_ATTENDANCE_DB_NAME=app_attendance
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=<mongo-user-local>
MONGO_INITDB_ROOT_PASSWORD=<mongo-password-local>
MONGO_URI=mongodb://<mongo-user-local>:<mongo-password-local>@mongo:27017/app_attendance?authSource=admin

# --- API backend ---
API_PORT=4000
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:5173
API_LOG_LEVEL=info

# --- App frontend ---
APP_PORT=8080
VITE_BACKEND_URL=http://localhost:4000

# --- Negocio ---
QR_DEFAULT_TTL_MINUTES=10
ROOM_CODE_TTL_SECONDS=90
PUBLIC_BASE_URL=http://localhost:5173

# --- Seguridad ---
JWT_SECRET=<cambiar-por-secreto-local-de-32-caracteres>
JWT_EXPIRES_IN=12h
BCRYPT_ROUNDS=10
